# Environment Variables Example
# Copy this file to .env and fill in your actual values

# API Endpoints (if connecting to backend)
VITE_API_URL=http://localhost:3000/api

# Smart Contract Addresses (to be filled when contracts are deployed)
VITE_CONTRACT_ADDRESS=
VITE_VERIFIER_ADDRESS=

# Network Configuration
VITE_CHAIN_ID=1
VITE_RPC_URL=

# Wallet Configuration
VITE_WALLET_CONNECT_ID=

# Feature Flags
VITE_ENABLE_MOCK_DATA=true
VITE_ENABLE_LOGGING=true

# Application Settings
VITE_MAX_PROPOSALS=1000
VITE_MAX_OPTIONS_PER_PROPOSAL=10
VITE_BLOCK_TIME_MS=12000
